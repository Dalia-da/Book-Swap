<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookSwap</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Montserrat:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa, #e3e8f0);
            font-family: 'Montserrat', sans-serif;
            margin: 0;
            overflow-x: hidden;
            position: relative;
            background-image: radial-gradient(circle at 50% 20%, rgba(255, 255, 255, 0.1) 0%, transparent 70%), /* ثلج خفيف */
            radial-gradient(circle at 80% 10%, rgba(255, 215, 0, 0.05) 0%, transparent 50%); /* لمسة ذهبية خفيفة */
        }

        .header {
            position: absolute;
            top: 20px;
            width: 100%;
            text-align: center;
            z-index: 2;
        }

            .header h1 {
                font-family: 'Playfair Display', serif;
                color: #d4af37; /* لون ذهبي فاخر */
                font-size: 2.5rem;
                text-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
                letter-spacing: 2px;
            }

        .hero {
            height: 80vh;
            position: relative;
            overflow: hidden;
            background: linear-gradient(135deg, rgba(0, 40, 60, 0.7), rgba(0, 80, 70, 0.7));
        }

            .hero video {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                filter: brightness(0.8);
            }

        .hero-content {
            position: relative;
            z-index: 1;
            color: white;
            text-align: center;
            padding-top: 15%;
            text-shadow: 0 0 15px rgba(255, 255, 255, 0.4);
        }

            .hero-content h1 {
                font-family: 'Playfair Display', serif;
                font-size: 4rem;
                font-weight: 700;
            }

            .hero-content p {
                font-size: 1.3rem;
                max-width: 700px;
                margin: 20px auto;
            }

        .custom-card {
            background: #fff;
            border-radius: 15px;
            overflow: hidden;
            transition: all 0.3s ease;
            border: 2px solid #d4af37; 
        }

            .custom-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 20px 40px rgba(0, 166, 90, 0.4);
            }

        .carousel-inner img {
            height: 400px;
            object-fit: cover;
            border-radius: 15px;
            border: 3px solid #d4af37;  
        }

        .carousel-control-prev-icon, .carousel-control-next-icon {
            background-color: #00a65a;
            border-radius: 50%;
            padding: 12px;
            box-shadow: 0 0 10px rgba(0, 166, 90, 0.3);
        }

        .designer-section {
            background: linear-gradient(135deg, #e3e8f0, #f5f7fa);
            padding: 50px 20px;
            text-align: center;
        }

            .designer-section img {
                width: 200px;
                height: 200px;
                border-radius: 50%;
                object-fit: cover;
                border: 5px solid #d4af37;  
                transition: transform 0.3s ease;
                box-shadow: 0 0 15px rgba(212, 175, 55, 0.2);
            }

                .designer-section img:hover {
                    transform: scale(1.1);
                }

        .btn-custom {
            border: none;
            border-radius: 25px;
            padding: 12px 30px;
            color: white;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-custom-primary {
            background: linear-gradient(135deg, #00a65a, #2e7d32);
        }

            .btn-custom-primary:hover {
                transform: translateY(-2px);
                background: linear-gradient(135deg, #008d5a, #1b5e20);
                box-shadow: 0 8px 20px rgba(0, 166, 90, 0.5);
            }

        .btn-custom-secondary {
            background: linear-gradient(135deg, #d4af37, #c0a062);  
        }

            .btn-custom-secondary:hover {
                transform: translateY(-2px);
                background: linear-gradient(135deg, #b8860b, #a68a64);
                box-shadow: 0 8px 20px rgba(212, 175, 55, 0.5);
            }

        .exclusive-offers {
            background: linear-gradient(135deg, #e0e7f0, #d0d9e5);
            padding: 50px 20px;
            text-align: center;
            margin-top: 50px;
        }

        .vip-membership {
            background: linear-gradient(135deg, #1a3c34, #004d40);
            color: #e0f7fa;
            padding: 60px 20px;
            text-align: center;
            margin-top: 50px;
        }

        .footer {
            background: linear-gradient(135deg, #1a3c34, #004d40);
            color: #e0f7fa;
            padding: 40px 0;
        }

            .footer a {
                color: #b2dfdb;
                transition: color 0.3s ease;
                font-weight: 600;
            }

                .footer a:hover {
                    color: #d4af37;  
                }

        .social-icons i {
            font-size: 1.7rem;
            margin: 0 15px;
            color: #d4af37;
            transition: transform 0.3s ease;
        }

            .social-icons i:hover {
                transform: scale(1.2);
            }
    </style>
</head>
<body>
     <div class="header">
        <h1>BookSwap</h1>
    </div>

     <section class="hero">
        <video autoplay muted loop class="w-100 h-100">
            <source src="~/videos/bookswapvideo.mp4" type="video/mp4" />
            Your browser does not support the video tag.
        </video>
        <div class="hero-content">
            <h1>Welcome to BookSwap</h1>
            <p>Discover, swap, and enjoy a world of books with our premium platform.</p>
            <a href="@Url.Action("LendHistory", "Books")" class="btn btn-custom-primary mt-4">Start Exploring</a>
        </div>
    </section>

     <div class="container mt-5">
        <h3 style="font-size: 2rem; font-weight: 700; color: #1a3c34; text-align: center; margin-bottom: 30px;">Featured Books</h3>
        <div id="bookCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="~/images/books/book1.jpg" class="d-block w-100" alt="Book 1">
                </div>
                <div class="carousel-item">
                    <img src="~/images/books/book2.jpg" class="d-block w-100" alt="Book 2">
                </div>
                <div class="carousel-item">
                    <img src="~/images/books/book3.jpg" class="d-block w-100" alt="Book 3">
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#bookCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#bookCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>

     <div class="designer-section">
        <h3 style="font-size: 2.5rem; font-weight: 700; margin-bottom: 30px; color: #1a3c34;">Meet Our Designer</h3>
        <div style="display: flex; justify-content: center; align-items: center; flex-wrap: wrap; gap: 20px;">
            <img src="~/images/carouselimages/dal.jpg" alt="Dalia's Picture">
            <div style="text-align: left; max-width: 400px;">
                <h4 style="font-size: 1.8rem; color: #0288d1; margin-bottom: 10px;">Dalia Ragab Ali</h4>
                <p style="font-size: 1.1rem; color: #666;">A passionate full stack .NET developer who crafted this stunning platform with creativity and precision.</p>
            </div>
        </div>
    </div>

     <div class="exclusive-offers">
        <h2 style="font-size: 2.5rem; font-weight: 700; color: #1a3c34; margin-bottom: 30px;">Exclusive Offers</h2>
        <p style="font-size: 1.2rem; max-width: 700px; margin: 20px auto; color: #666;">Unlock rare editions and special discounts with our exclusive book offers.</p>
        <div style="display: flex; justify-content: center; gap: 30px; flex-wrap: wrap;">
            <div class="custom-card" style="max-width: 300px; padding: 20px;">
                <p style="font-size: 1.1rem; color: #1a3c34;">Limited Edition Classic - 20% Off</p>
                <a href="#" class="btn btn-custom-secondary mt-3">Claim Offer</a>
            </div>
            <div class="custom-card" style="max-width: 300px; padding: 20px;">
                <p style="font-size: 1.1rem; color: #1a3c34;">Signed Author Copy - 30% Off</p>
                <a href="#" class="btn btn-custom-secondary mt-3">Claim Offer</a>
            </div>
        </div>
    </div>

     <div class="vip-membership">
        <h2 style="font-size: 2.5rem; font-weight: 700; margin-bottom: 30px;">VIP Membership</h2>
        <p style="font-size: 1.2rem; max-width: 700px; margin: 20px auto;">Unlock exclusive perks for free! Enjoy early access to new books, a VIP badge, personal stats, and faster support by reaching 10 swaps.</p>
        <a href="@Url.Action("Membership", "Home")" class="btn btn-custom-primary mt-3">Earn VIP Status</a>
    </div>

     <div style="background: linear-gradient(135deg, #1a3c34, #004d40); color: white; padding: 60px 20px; text-align: center; margin-top: 50px;">
        <h2 style="font-size: 2.5rem; font-weight: 700;">Join the BookSwap Community!</h2>
        <p style="font-size: 1.2rem; max-width: 700px; margin: 20px auto;">Start swapping books today and unlock a world of reading possibilities.</p>
        <a href="@Url.Action("LendHistory", "Books")" class="btn btn-custom-primary mt-3">Join Now</a>
    </div>

     <div style="background: #fff; padding: 50px 20px; text-align: center;">
        <h3 style="font-size: 2.5rem; font-weight: 700; margin-bottom: 30px; color: #6d4c41;">What Our Users Say</h3>
        <div style="display: flex; justify-content: center; gap: 30px; flex-wrap: wrap;">
            <div class="custom-card" style="max-width: 300px; padding: 20px;">
                <p style="font-style: italic; color: #666; font-size: 1.1rem;">"An incredible experience swapping books with ease!"</p>
                <p style="font-weight: 600; color: #0288d1; margin-top: 10px;">- Ahmed S.</p>
            </div>
            <div class="custom-card" style="max-width: 300px; padding: 20px;">
                <p style="font-style: italic; color: #666; font-size: 1.1rem;">"The best community for book lovers!"</p>
                <p style="font-weight: 600; color: #0288d1; margin-top: 10px;">- Sara M.</p>
            </div>
        </div>
    </div>

     <footer class="footer text-center">
        <div class="container">
            <p>© 2025 BookSwap. All rights reserved.</p>
            <div class="mt-3">
                <a href="@Url.Action("Privacy", "Home")">Privacy Policy</a> |
                <a href="@Url.Action("Terms", "Home")">Terms of Service</a> |
                <a href="mailto:dalia18.com@gmail.com">Contact Support</a>
            </div>
            <div class="mt-3 social-icons">
                <a href="#" class="me-3"><i class="fab fa-facebook-f"></i></a>
                <a href="#" class="me-3"><i class="fab fa-twitter"></i></a>
                <a href="#" class="me-3"><i class="fab fa-instagram"></i></a>
                <a href="#" class="me-3"><i class="fab fa-linkedin-in"></i></a>
            </div>
        </div>
    </footer>
</body>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</html>