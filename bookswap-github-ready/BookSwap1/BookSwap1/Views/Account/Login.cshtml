@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

 <div class="container-fluid" style="background-color: #f5f5f5; padding-top: 30px; padding-bottom: 50px;">
    <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
         <div class="col-12 col-md-6 text-center text-md-start" style="margin-bottom: 30px;">
            <img src="https://bookswap.fr/assets/images/bookswap-logo.svg" alt="BookSwap Logo" style="width: 500px; margin-bottom: 50px; margin-left: 100px;">
            <p class="mt-3" style="font-size: 2rem; font-weight: bold;">Swap your books for exciting new reads</p>
            <p style="font-size: 1.2rem;">Enter your details to log in:</p>

             <form method="post" action="/Account/Login" class="form-inline">
                 <div class="input-group" style="max-width: 400px; margin-bottom: 20px;">
                    <input type="email" class="form-control" placeholder="Enter your email..." required name="Email" style="font-size: 1.1rem; border-radius: 30px;">
                </div>

                 <div class="input-group" style="max-width: 400px;">
                    <input type="password" class="form-control" placeholder="Enter your password..." required name="Password" style="font-size: 1.1rem; border-radius: 30px;">
                </div>

                 <div class="mt-3">
                    <button type="submit" class="btn btn-primary" style="font-size: 1.1rem; border-radius: 30px;">Login</button>
                </div>
            </form>

             <div class="mt-3">
                <a href="@Model.ForgetPasswordUrl" class="btn btn-link" style="font-size: 1.1rem;">Forgot Password?</a>
            </div>

             <div class="mt-3">
                <p class="text-muted" style="font-size: 1.1rem;">Don't have an account?</p>
                <a href="/Account/Register" class="btn btn-outline-success" style="font-size: 1.1rem; border-radius: 30px;">Register Now</a>
            </div>

            <small class="text-muted mt-2 d-block" style="font-size: 1rem;">* Your details will be used solely for login purposes and will not be shared with any other parties.</small>
        </div>

         <div class="col-12 col-md-6 text-center">
            <img src="https://bookswap.co.uk/app2.png" alt="Phone Mockup" style="max-width: 70%; height: auto; margin-top: 30px;">
        </div>
    </div>
</div>