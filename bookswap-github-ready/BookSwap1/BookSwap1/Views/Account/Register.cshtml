@model BookSwap.Models.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

 <div class="container-fluid" style="background-color: #f5f5f5; padding: 80px 0;">
    <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
         <div class="col-12 col-md-6">
            <div style="padding: 50px;">
                <h1 class="display-5 fw-bold" style="color: #333;">THE SAME STORY, JUST IN DIFFERENT HANDS</h1>
                <p class="mt-3" style="font-size: 1.2rem;">Get <strong>10 bonus points</strong> for the first 10 books you offer and exchange them for the reads you want.</p>
                <a href="#" class="btn btn-primary mt-3" style="background-color: #1abc9c; border: none; padding: 10px 30px; font-size: 1.2rem; border-radius: 30px;">Get Started</a>


               
                 <form autocomplete="off" method="post" action="/Account/Register" enctype="multipart/form-data" class="mt-5">
 
                    <div class="mb-3">

                        @Html.ValidationSummary()
                    </div>


                    <div class="form-floating mb-3">
                        @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Name" })
                        <label for="Name">Name</label>
                    </div>

                     <div class="form-floating mb-3">
                        @Html.TextAreaFor(m => m.Address, new { @class = "form-control", placeholder = "Address" })
                        <label for="Address">Address</label>
                    </div>

                     <div class="form-floating mb-3">
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Email" })
                        <label for="Email">Email</label>
                    </div>

                     <div class="input-box underline mb-3">
                        <input type="file" name="Images" accept="image/*" required>
                        <div class="underline"></div>
                    </div>
                    <div class="form-group">
                        <label asp-for="Role" class="control-label"></label>
                        <select asp-for="Role" class="form-control">
                            <option value="User"> User </option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                     <div class="form-floating mb-3">
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Password", id = "passwordField" })
                        <label for="passwordField">Password</label>
                    </div>

                     <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="showPassword" onclick="togglePasswordVisibility()">
                        <label class="form-check-label" for="showPassword">Show Password</label>
                    </div>

                     <button type="submit" class="btn btn-success w-100 p-2" style="background-color: #1abc9c; border-radius: 30px; font-size: 1.2rem;">Register</button>
                </form>
            </div>
        </div>

         <div class="col-12 col-md-6 text-center">
             <img src="https://bookswap.fr/assets/images/bookswap-fr-banner.jpg" alt="BookSwap Banner" class="img-fluid" style="max-width: 100%; height: auto; object-fit: cover; width: auto; height: 150%;">
        </div>
    </div>
</div>

 <script>
    function togglePasswordVisibility() {
        var passwordField = document.getElementById("passwordField");
        var showPasswordCheckbox = document.getElementById("showPassword");

         if (showPasswordCheckbox.checked) {
            passwordField.type = "text";  
        } else {
            passwordField.type = "password";
        }
    }
</script>
