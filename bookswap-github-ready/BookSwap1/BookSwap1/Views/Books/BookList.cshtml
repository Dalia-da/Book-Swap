@model List<BookSwap.Models.AddBookViewModel>

@{
    ViewData["Title"] = "Book List";
}


<h2 class="text-center">قائمة الكتب</h2>

<div class="container">
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>العنوان</th>
                <th>المؤلف</th>
                <th>النوع</th>
                <th>سنة النشر</th>
                <th>ISBN</th>

                <th>الصورة</th>
                <th>خيارات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.Genre</td>
                    <td>@book.YearPublished</td>
                    <td>@book.ISBN</td>

                    <td>
                        @if (!string.IsNullOrEmpty(book.ImagePath))
                        {
                            <img src="@book.ImagePath" alt="صورة الكتاب" style="width: 100px; height: auto;" />
                        }
                        else
                        {
                            <span>لا توجد صورة</span>
                        }
                    </td>
                    <td>
                        <a asp-action="EditBook" asp-route-id="@book.Id" class="btn btn-primary">تعديل</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

 <style>
    body {
        background-color: #f8f9fa;
    }

    h2 {
        color: #007bff;
        font-weight: bold;
    }

    .container {
        margin-top: 50px;
    }

    .table {
        border-radius: 8px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        background-color: #ffffff;
    }

    .thead-dark {
        background-color: #343a40;
        color: white;
    }

    .table th, .table td {
        vertical-align: middle;
        text-align: center;
        font-size: 1rem;
    }

    .table-hover tbody tr:hover {
        background-color: #f1f1f1;
        transform: scale(1.02);
        transition: transform 0.2s ease-in-out;
    }

    .table-striped tbody tr:nth-child(odd) {
        background-color: #f9f9f9;
    }

    .table-bordered {
        border: 1px solid #dee2e6;
    }

    .table td {
        font-weight: normal;
    }

    .table th {
        font-weight: bold;
    }
</style>
