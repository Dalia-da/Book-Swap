@model List<BookSwap.Models.BookCategoryViewModel>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Categories</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #f5f5f5;
            font-family: 'Roboto', sans-serif;
            overflow-x: hidden;
        }

        h1 {
            font-size: 3.5rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 2px 2px 6px rgba(0, 0, 0, 0.3);
        }

        .search-bar {
            border-radius: 50px;
            padding: 15px;
            font-size: 1.2rem;
            border: none;
            transition: all 0.3s ease;
        }

        .btn-gradient {
            background: linear-gradient(45deg, #ff5e62, #feb47b);
            border-radius: 50px;
            color: #fff;
            padding: 15px 30px;
            font-size: 1.2rem;
            transition: all 0.3s ease;
            border: none;
        }

        .custom-card {
            border-radius: 20px;
            background: #ffffff;
            transition: box-shadow 0.4s ease, transform 0.3s ease;
            height: 100%;
            display: flex;
            flex-direction: column;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 100%;
            margin: auto;
        }

            .custom-card:hover {
                box-shadow: 0 4px 15px rgba(255, 94, 98, 0.7), 0 8px 30px rgba(254, 180, 123, 0.8);
                transform: scale(1.02);
            }

        .card-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: #333;
            text-align: center;
        }

        .book-item {
            padding: 15px;
            border-radius: 12px;
            background-color: #f8f9fa;
            margin-bottom: 20px;
            transition: background-color 0.3s ease, transform 0.3s ease;
        }

            .book-item:hover {
                background-color: #e2e6ea;
                transform: translateY(-3px);
            }

            .book-item img {
                border-radius: 10px;
                width: 100%;
                height: auto;
                object-fit: cover;
            }

            .book-item a {
                font-size: 1.1rem;
                padding: 12px 30px;
                border-radius: 25px;
                transition: background-color 0.3s ease, transform 0.3s ease;
                background: linear-gradient(45deg, #ff5e62, #feb47b);
                color: white;
                border: none;
                display: inline-block;
                margin-right: 10px; /* مسافة بين الروابط */
            }

                .book-item a:hover {
                    background-color: #feb47b;
                    transform: scale(1.05);
                }
    </style>
</head>
<body>
    <h1 class="text-center my-5 font-weight-bold text-light">Book Categories</h1>

    <form method="get" action="@Url.Action("BookCategories", "Books")" class="mb-5 position-relative">
        <div class="input-group search-group">
            <input type="text" name="searchTerm" class="form-control search-bar" placeholder="Search for books..." value="@ViewData["searchTerm"]" />
            <button class="btn btn-gradient" type="submit">
                <i class="fas fa-search"></i> Search
            </button>
        </div>
    </form>

    <div class="container mt-5">
        <div class="row">
            @foreach (var category in Model)
            {
                <div class="col-md-4 col-sm-12 mb-5">
                    <div class="card custom-card">
                        <div class="card-body">
                            <h4 class="card-title text-center text-secondary">@category.Genre</h4>
                            <ul class="list-unstyled mt-3">
                                @foreach (var book in category.Books)
                                {
                                    <li class="book-item text-center">
                                        <img src="@book.ImagePath" alt="@book.Title" class="img-fluid mb-3 book-image" />
                                        <div>
                                            <strong class="d-block text-secondary" style="font-size: 1.2rem;">@book.Title</strong>
                                            <span class="d-block text-muted" style="font-size: 1rem;">@book.Author</span>
                                            <span class="d-block text-muted" style="font-size: 0.9rem;">(@book.YearPublished)</span>
                                            <span class="d-block text-secondary" style="font-size: 0.9rem;">(@book.ISBN)</span>
                                        </div>
                                        <div>
                                            <a href="@Url.Action("LendBook", "Books", new { bookId = book.Id })" class="btn btn-primary btn-sm mt-3">
                                                Add to my library
                                            </a>
                                            <a href="@Url.Action("Details", "Books", new { id = book.Id })" class="btn btn-primary btn-sm mt-3">
                                                عرض التفاصيل
                                            </a>
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>