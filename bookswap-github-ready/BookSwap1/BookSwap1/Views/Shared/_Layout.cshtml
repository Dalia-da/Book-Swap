<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookSwap Application</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/css/jquery-ui.min.css" />
    <style>
        body {
            background-color: #f5f5f5;
            font-family: 'Roboto', sans-serif;
        }

        .user-image-container img {
            width:40px;   
            height:40px;
            border-radius: 50%;
            object-fit: cover;
        }

        header {
            background-color: #f5f5f5;
            color:#f5f5f5;
            padding: 5px 0;   
            box-shadow: 0 2px 4px #f5f5f5(0, 0, 0, 0.1);
        }

        .navbar {
            padding: 0.5rem 1rem;  
        }

        .navbar-nav .nav-item {
            margin-left: 15px;   
        }

        .navbar-nav .nav-link {
            color:#f5f5f5;
            font-size:14px;  
            font-weight: 500;  
        }

        .navbar-nav .nav-link:hover {
            color: #ffc107 !important;
        }

        .btn-primary {
            background-color: #28a745;
            border-color: #28a745;
        }

        .btn-primary:hover {
            background-color: #218838;
            border-color: #1e7e34;
        }

        .btn-custom {
            background-color: #dc3545;
            color: white;
            border-radius: 5px;
            padding: 8px 12px;  
            display: inline-flex;
            align-items: center;
        }

        .custom-footer {
            background-color: #f5f5f5;
            padding: 20px;
            text-align: center;
        }

        .btn-custom i {
            margin-right: 5px;  
        }
    </style>
</head>

<body>
    <header class="position-sticky top-0">
        <nav class="navbar navbar-expand-lg navbar-light" style="background-color: transparent;">
            <div class="container-fluid">
                <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                    <img src="~/images/carouselimages/bbook-removebg-preview.png" alt="BookSwap Logo" style="width: 150px; height: auto;" /> <!-- تقليص حجم الشعار -->
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("AddBook", "Books")">
                                    <i class="fas fa-plus-circle"></i> Add Book
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("BookList", "Books")">
                                    <i class="fas fa-list"></i> Book List
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("BookCategories", "Books")">
                                <i class="fas fa-book"></i> Books
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("LendHistory", "Books")">
                                <i class="fas fa-history"></i> lend now!
                            </a>
                        </li>
                    </ul>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="ms-3">
                            <a class="btn btn-primary" href="@Url.Action("Logout", "Account")">
                                <i class="fas fa-sign-out-alt"></i> Logout
                            </a>
                        </div>
                        <div class="user-image-container ms-3">
                            <a href="@Url.Action("Profile", "Account", new { userId = ViewData["UserId"] })">
                                @if (ViewData["UserImagePath"] != null)
                                {
                                    <img src="@Url.Content(ViewData["UserImagePath"]?.ToString())" alt="User Image" />
                                }
                            </a>
                        </div>
                    }
                    else
                    {
                        <div>
                            <a class="d-flex align-items-center" href="@Url.Action("Login", "Account")" style="color: #dc3545; font-size: 16px; font-weight: bold; text-decoration: none;">
                                <i class="fas fa-door-open fs-3 me-2"></i> Login
                            </a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer style="background-color: #f5f5f5; padding: 20px; text-align: center;">
        <p class="mb-0" style="color: #4A90E2;">BookSwap | Every book has a story</p>
        <div class="mt-4">
            <a href="https://www.instagram.com/" class="fs-3 mx-3" target="_blank"><i class="fab fa-instagram"></i></a>
            <a href="https://web.whatsapp.com/send?phone=01148683303" class="fs-3 mx-3" target="_blank"><i class="fab fa-whatsapp"></i></a>
            <a href="https://www.facebook.com/" class="fs-3 mx-3" target="_blank"><i class="fab fa-facebook"></i></a>
            <a href="mailto:example@example.com" class="fs-3 mx-3" target="_blank"><i class="far fa-envelope"></i></a>
        </div>
        <p class="mt-3" style="color: #4A90E2;">Address: Egypt, Assuit, City-Street</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/jquery-ui.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
